{
  "name": "hugo-website",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/hugo-website",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          {
            "command": "tailwindcss -i assets/css/styles.css -o static/css/styles.css --minify"
          },
          {
            "command": "hugo -d ../../dist/apps/hugo-website --gc --minify --baseURL \"${BASE_URL:-/}\""
          }
        ],
        "parallel": false,
        "cwd": "apps/hugo-website"
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          {
            "command": "tailwindcss -i assets/css/styles.css -o static/css/styles.css --watch"
          },
          {
            "command": "hugo server -D"
          }
        ],
        "parallel": true,
        "cwd": "apps/hugo-website"
      }
    },
    "preview": {
      "executor": "nx:run-commands",
      "options": {
        "command": "hugo -d ../../dist/apps/hugo-website-preview --gc --minify --baseURL /preview/",
        "cwd": "apps/hugo-website"
      }
    }
  }
}
