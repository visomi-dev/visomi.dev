---
import { createTranslator, getPagePath, locales, type Locale, type PageId } from '../i18n/translations';
import ThemeSwitcher from './theme-switcher.astro';

type Props = {
  locale: Locale;
  currentPage: PageId;
};

const { locale, currentPage } = Astro.props;
const t = createTranslator(locale);
const navItems = [
  { page: 'home', label: t('navHome') },
  { page: 'journey', label: t('navJourney') },
  { page: 'projects', label: t('navProjects') },
  { page: 'contact', label: t('navContact') },
  { page: 'resume', label: t('navResume') },
] as const;
---

<nav
  class="fixed top-0 left-0 z-50 w-full border-b border-neutral-200 bg-white/50 backdrop-blur-sm dark:border-neutral-800 dark:bg-black/50"
>
  <div class="mx-auto flex h-20 max-w-7xl items-center justify-between px-6 lg:px-12">
    <a href={getPagePath(locale, 'home')} class="flex items-center gap-3">
      <div class="h-2 w-2 rounded-full bg-black dark:bg-white"></div>
      <span class="font-mono text-lg font-bold tracking-tight dark:text-white">VISOMI.DEV</span>
    </a>

    <div class="hidden items-center gap-8 font-mono tracking-widest text-gray-500 md:flex dark:text-gray-400">
      {
        navItems.map((item) => (
          <a
            href={getPagePath(locale, item.page)}
            class={`transition-colors hover:text-black dark:hover:text-white ${currentPage === item.page ? 'text-black dark:text-white' : ''}`}
            aria-current={currentPage === item.page ? 'page' : undefined}
          >
            {item.label}
          </a>
        ))
      }
    </div>

    <div class="flex items-center gap-4">
      <div class="flex items-center font-mono text-xs tracking-widest text-neutral-500 dark:text-neutral-400">
        {
          locales.map((itemLocale, index) => (
            <>
              {index > 0 && <span class="mx-1">/</span>}
              <a
                href={getPagePath(itemLocale, currentPage)}
                class={
                  itemLocale === locale
                    ? 'font-bold text-black dark:text-white'
                    : 'hover:text-black dark:hover:text-white'
                }
                hreflang={itemLocale}
              >
                {itemLocale.toUpperCase()}
              </a>
            </>
          ))
        }
      </div>

      <ThemeSwitcher />

      <button
        id="mobile-menu-btn"
        class="p-2 text-neutral-500 transition-colors hover:text-black md:hidden dark:text-neutral-400 dark:hover:text-white"
        aria-label="Open menu"
      >
        <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>
  </div>

  <div
    id="mobile-menu"
    class="hidden border-t border-neutral-200 bg-white/95 backdrop-blur-md md:hidden dark:border-neutral-800 dark:bg-black/95"
  >
    <div class="flex flex-col space-y-4 px-6 py-6 font-mono tracking-widest">
      {
        navItems.map((item) => (
          <a
            href={getPagePath(locale, item.page)}
            class={`py-2 text-neutral-600 hover:text-black dark:text-neutral-400 dark:hover:text-white ${currentPage === item.page ? 'font-bold text-black dark:text-white' : ''}`}
            aria-current={currentPage === item.page ? 'page' : undefined}
          >
            {item.label}
          </a>
        ))
      }
    </div>
  </div>

  <script src="../scripts/navbar.ts"></script>
</nav>
