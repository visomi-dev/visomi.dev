---
import { Image } from 'astro:assets';

import { getSiteContent } from '../content/site-content';
import { getPagePath, type Locale } from '../i18n/translations';

type Props = {
  locale: Locale;
};

const { locale } = Astro.props;
const { featuredProjects, home } = getSiteContent(locale);

const toneStyles = {
  emerald:
    'border-emerald-100 bg-emerald-50 text-emerald-600 dark:border-emerald-800 dark:bg-emerald-900/30 dark:text-emerald-400',
  blue: 'border-blue-100 bg-blue-50 text-blue-600 dark:border-blue-800 dark:bg-blue-900/30 dark:text-blue-400',
  neutral:
    'border-border-light text-muted-light dark:border-border-dark dark:text-muted-dark bg-neutral-100 dark:bg-neutral-800',
} as const;
---

<section
  class="min-h-screen-nav relative z-10 mt-20 flex flex-col items-center justify-center px-6 pt-20 pb-12 text-center"
>
  <div class="animate-fade-in-up mx-auto max-w-5xl space-y-8">
    <div
      class="border-border-light dark:border-border-dark mb-4 inline-flex items-center space-x-2 rounded-full border bg-white/60 px-3 py-1 shadow-sm backdrop-blur-sm dark:bg-white/5"
    >
      <span class="relative flex h-2 w-2">
        <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-emerald-500 opacity-75"></span>
        <span class="relative inline-flex h-2 w-2 rounded-full bg-emerald-500"></span>
      </span>
      <span class="text-muted-light dark:text-muted-dark text-xs font-medium tracking-wide uppercase"
        >{home.heroBadge}</span
      >
    </div>

    <h1
      class="text-4xl leading-tight font-bold tracking-tight text-neutral-900 sm:text-5xl md:text-7xl md:leading-[1.1] lg:text-8xl dark:text-white"
    >
      <span class="block">{home.heroTitleLine1}</span>
      <span
        class="block bg-linear-to-r from-neutral-900 to-neutral-500 bg-clip-text text-transparent dark:from-white dark:to-neutral-500"
      >
        {home.heroTitleLine2}
      </span>
    </h1>

    <p class="text-muted-light dark:text-muted-dark mx-auto max-w-3xl text-lg leading-relaxed font-light md:text-xl">
      {home.heroSubtitle}
    </p>

    <div class="flex flex-col items-center justify-center gap-4 pt-8 sm:flex-row">
      <a
        class="group relative rounded-full bg-neutral-900 px-8 py-3 font-medium text-white shadow-lg shadow-black/5 transition-all hover:scale-105 hover:bg-neutral-900/90 active:scale-95 dark:bg-white dark:text-black dark:shadow-white/5 dark:hover:bg-white/90"
        href="#works"
      >
        {home.heroPrimaryCta}
        <span
          class="absolute inset-0 rounded-full ring-2 ring-black/5 transition-all group-hover:ring-black/10 dark:ring-white/10 dark:group-hover:ring-white/20"
        ></span>
      </a>
      <a
        class="border-border-light dark:border-border-dark rounded-full border bg-white px-8 py-3 font-medium text-neutral-900 shadow-sm transition-all hover:border-neutral-400/30 hover:bg-neutral-100 dark:bg-neutral-900 dark:text-white dark:hover:border-neutral-600 dark:hover:bg-neutral-800"
        href={getPagePath(locale, 'resume')}
      >
        {home.heroSecondaryCta}
      </a>
    </div>
  </div>

  <div class="absolute bottom-10 left-1/2 -translate-x-1/2 animate-bounce">
    <span class="pi pi-angle-down text-muted-light dark:text-muted-dark text-2xl"></span>
  </div>
</section>

<section class="px-4 py-20" id="journey">
  <div class="mx-auto max-w-5xl">
    <h2 class="mb-16 text-3xl font-bold tracking-tight text-neutral-900 md:text-4xl dark:text-white">
      {home.journeyTitle}
    </h2>

    <div class="border-border-light/80 relative ml-3 space-y-16 border-l md:ml-6 dark:border-neutral-700">
      {
        home.journeyItems.map((item) => (
          <div class="group relative pl-8 md:pl-12">
            <span class="bg-border-light ring-surface-light absolute top-2 -left-[5px] h-2.5 w-2.5 rounded-full ring-4 transition-colors group-hover:bg-neutral-900 dark:bg-neutral-500 dark:ring-black dark:group-hover:bg-white" />

            <div class="mb-4 flex flex-col gap-4 md:flex-row md:items-start md:justify-between">
              <span class="text-muted-light/20 text-4xl font-bold tabular-nums dark:text-neutral-700">{item.year}</span>
              <div class="md:text-right">
                <h3 class="text-xl font-semibold text-neutral-900 dark:text-white">{item.role}</h3>
                <p class="text-muted-light text-sm font-medium dark:text-neutral-400">{item.company}</p>
              </div>
            </div>

            <div class="border-border-light rounded-xl border bg-white/90 p-6 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-lg dark:border-neutral-700 dark:bg-neutral-900/80">
              <p class="text-muted-light leading-relaxed dark:text-neutral-300">{item.description}</p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<section id="works" class="mx-auto max-w-6xl px-4 py-20">
  <div class="mb-12 flex flex-col items-end justify-between md:flex-row">
    <div>
      <h2 class="mb-2 text-3xl font-bold tracking-tight text-neutral-900 md:text-4xl dark:text-white">
        {home.worksTitle}
      </h2>
      <p class="text-muted-light dark:text-muted-dark">{home.worksSubtitle}</p>
    </div>
    <a
      class="hover:text-muted-light dark:hover:text-muted-dark mt-4 hidden items-center gap-1 font-medium text-neutral-900 transition-colors md:mt-0 md:flex dark:text-white"
      href="https://github.com/visomi-dev"
      target="_blank"
    >
      <span>{home.worksLinkLabel}</span>
      <span class="pi pi-arrow-up-right text-sm"></span>
    </a>
  </div>

  <div class="grid grid-cols-1 gap-6 lg:grid-cols-3">
    {
      featuredProjects.map((project, index) => (
        <a
          href={getPagePath(locale, 'projects')}
          class="group border-border-light dark:border-border-dark relative overflow-hidden rounded-2xl border bg-white shadow-sm transition-colors duration-300 hover:border-neutral-400/40 hover:shadow-md dark:bg-neutral-900 dark:hover:border-neutral-600"
        >
          <div class="relative h-48 overflow-hidden bg-neutral-100 dark:bg-neutral-800">
            {project.screenshots[0] ? (
              <Image
                src={project.screenshots[0].src}
                alt={project.screenshots[0].alt}
                class="h-full w-full object-cover object-top transition-transform duration-500 group-hover:scale-105"
                widths={[480, 768]}
                sizes="(min-width: 1024px) 33vw, 100vw"
              />
            ) : (
              <div class="flex h-full w-full items-center justify-center bg-linear-to-br from-blue-100 to-cyan-100 transition-transform duration-500 group-hover:scale-105 dark:from-blue-900/30 dark:to-cyan-900/30">
                <span class:list={['pi text-5xl text-blue-400/60 dark:text-blue-400/40', project.icon]} />
              </div>
            )}

            <div class="text-muted-light/10 dark:text-muted-dark/10 absolute top-4 left-4 text-5xl font-black select-none">
              0{index + 1}
            </div>
            <div class="absolute right-4 bottom-4 rounded-full border border-white/50 bg-black/25 px-2 py-1 font-mono text-[10px] tracking-[0.2em] text-white uppercase backdrop-blur-sm">
              {project.category}
            </div>
          </div>
          <div class="p-6">
            <div class="mb-4 flex items-start justify-between gap-4">
              <h3 class="text-xl font-semibold text-neutral-900 dark:text-white">{project.title}</h3>
              <span class="pi pi-arrow-up-right text-muted-light dark:text-muted-dark transition-colors group-hover:text-neutral-900 dark:group-hover:text-white" />
            </div>
            <p class="text-surface-dark/80 dark:text-surface-light/80 mb-3 text-sm font-medium">{project.role}</p>
            <p class="text-muted-light dark:text-muted-dark mb-4 text-sm">{project.summary}</p>
            <div class="flex flex-wrap gap-2">
              {project.technologies.slice(0, 3).map((tag) => (
                <span class="border-border-light text-muted-light dark:border-border-dark dark:text-muted-dark rounded-md border bg-neutral-50 px-2 py-1 text-xs font-medium dark:bg-neutral-800">
                  {tag}
                </span>
              ))}
            </div>
          </div>
        </a>
      ))
    }
  </div>
</section>

<section class="px-4 pt-20" id="features">
  <div class="mx-auto max-w-6xl">
    <div class="mb-16 text-center">
      <h2 class="mb-4 text-3xl font-bold tracking-tight text-neutral-900 md:text-4xl dark:text-white">
        {home.featuresTitle}
      </h2>
      <p class="text-muted-light dark:text-muted-dark mx-auto max-w-2xl text-lg">{home.featuresSubtitle}</p>
    </div>

    <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
      {
        home.features.map((feature) => (
          <div class="group border-border-light dark:border-border-dark rounded-2xl border bg-white p-8 shadow-sm transition-all duration-300 hover:border-neutral-400/40 hover:shadow-md dark:bg-neutral-900 dark:hover:border-neutral-600">
            <div class="mb-6 flex items-start justify-between gap-4">
              <div>
                <h3 class="text-lg font-bold text-neutral-900 dark:text-white">{feature.title}</h3>
                <p class="text-muted-light dark:text-muted-dark text-sm">{feature.subtitle}</p>
              </div>
              <span class:list={['rounded border px-2 py-1 font-mono text-xs', toneStyles[feature.tone]]}>
                {feature.badge}
              </span>
            </div>
            <div class="border-border-light text-muted-light dark:border-border-dark dark:text-muted-dark rounded-lg border bg-neutral-50 p-4 font-mono text-[11px] dark:bg-neutral-800">
              {feature.lines.map((line) => (
                <p class="mb-1 last:mb-0">{line}</p>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
