---
import { createTranslator, getPagePath, type Locale } from '../i18n/translations';

type Props = {
  locale: Locale;
};

const { locale } = Astro.props;
const t = createTranslator(locale);

const journeyItems = [
  {
    year: '2022',
    role: 'homeJourneyRole2022',
    company: 'homeJourneyCompany2022',
    description:
      'Leading technical architecture and development of enterprise-scale systems using React, Node.js on Azure. Designed and implemented data ingestion pipelines and real-time visualization dashboards.',
  },
  {
    year: '2021',
    role: 'homeJourneyRole2021',
    company: 'homeJourneyCompany2021',
    description:
      'Oversaw technology strategy and product development. Architected secure financial platforms using React, Node.js, and AWS Serverless infrastructure. Managed cross-functional engineering teams.',
  },
  {
    year: '2020',
    role: 'homeJourneyRole2020',
    company: 'homeJourneyCompany2020',
    description:
      'Drove the migration to Nx monorepo and AWS infrastructure. Developed scalable frontend services with Angular and backend systems using Serverless. Integrated complex authentication flows with AWS Cognito.',
  },
  {
    year: '2018',
    role: 'homeJourneyRole2018',
    company: 'homeJourneyCompany2018',
    description:
      'Architected fiscal and accounting applications using Node.js, PostgreSQL, and Vue. Managed development teams and interfaced with government SAT services for compliance.',
  },
] as const;
---

<section
  class="min-h-screen-nav relative z-10 mt-20 flex flex-col items-center justify-center px-6 py-24 pt-20 text-center"
>
  <div class="animate-fade-in-up mx-auto max-w-4xl space-y-8">
    <div
      class="border-border-light dark:border-border-dark mb-4 inline-flex items-center space-x-2 rounded-full border bg-white/60 px-3 py-1 shadow-sm backdrop-blur-sm dark:bg-white/5"
    >
      <span class="relative flex h-2 w-2">
        <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-emerald-500 opacity-75"></span>
        <span class="relative inline-flex h-2 w-2 rounded-full bg-emerald-500"></span>
      </span>
      <span class="text-muted-light dark:text-muted-dark text-xs font-medium tracking-wide uppercase"
        >{t('homeHeroBadge')}</span
      >
    </div>

    <h1
      class="text-4xl leading-tight font-bold tracking-tight text-neutral-900 sm:text-5xl md:text-7xl md:leading-[1.1] lg:text-8xl dark:text-white"
    >
      <span class="block">{t('homeHeroTitleLine1')}</span>
      <span
        class="block bg-linear-to-r from-neutral-900 to-neutral-500 bg-clip-text text-transparent dark:from-white dark:to-neutral-500"
      >
        {t('homeHeroTitleLine2')}
      </span>
    </h1>

    <p
      class="text-muted-light dark:text-muted-dark mx-auto max-w-2xl text-lg leading-relaxed font-light md:text-xl"
      set:html={t('homeHeroSubtitle')}
    />

    <div class="flex flex-col items-center justify-center gap-4 pt-8 sm:flex-row">
      <a
        class="group relative rounded-full bg-neutral-900 px-8 py-3 font-medium text-white shadow-lg shadow-black/5 transition-all hover:scale-105 hover:bg-neutral-900/90 active:scale-95 dark:bg-white dark:text-black dark:shadow-white/5 dark:hover:bg-white/90"
        href="#works"
      >
        {t('homeHeroCtaWork')}
        <span
          class="absolute inset-0 rounded-full ring-2 ring-black/5 transition-all group-hover:ring-black/10 dark:ring-white/10 dark:group-hover:ring-white/20"
        ></span>
      </a>
      <a
        class="border-border-light dark:border-border-dark rounded-full border bg-white px-8 py-3 font-medium text-neutral-900 shadow-sm transition-all hover:border-neutral-400/30 hover:bg-neutral-100 dark:bg-neutral-900 dark:text-white dark:hover:border-neutral-600 dark:hover:bg-neutral-800"
        href={getPagePath(locale, 'resume')}
      >
        {t('homeHeroCtaCv')}
      </a>
    </div>
  </div>

  <div class="absolute bottom-10 left-1/2 -translate-x-1/2 animate-bounce">
    <span class="pi pi-angle-down text-muted-light dark:text-muted-dark text-2xl"></span>
  </div>
</section>

<section class="px-4 py-20" id="journey">
  <div class="mx-auto max-w-5xl">
    <h2 class="mb-16 text-3xl font-bold tracking-tight text-neutral-900 md:text-4xl dark:text-white">
      {t('homeJourneyTitle')}
    </h2>

    <div class="border-border-light/80 relative ml-3 space-y-16 border-l md:ml-6 dark:border-neutral-700">
      {
        journeyItems.map((item) => (
          <div class="group relative pl-8 md:pl-12">
            <span class="bg-border-light ring-surface-light absolute top-2 -left-[5px] h-2.5 w-2.5 rounded-full ring-4 transition-colors group-hover:bg-neutral-900 dark:bg-neutral-500 dark:ring-black dark:group-hover:bg-white" />

            <div class="mb-4 flex flex-col gap-4 md:flex-row md:items-start md:justify-between">
              <span class="text-muted-light/20 text-4xl font-bold tabular-nums dark:text-neutral-700">{item.year}</span>
              <div class="md:text-right">
                <h3 class="text-xl font-semibold text-neutral-900 dark:text-white">{t(item.role)}</h3>
                <p class="text-muted-light text-sm font-medium dark:text-neutral-400">{t(item.company)}</p>
              </div>
            </div>

            <div class="border-border-light rounded-xl border bg-white/90 p-6 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-lg dark:border-neutral-700 dark:bg-neutral-900/80">
              <p class="text-muted-light leading-relaxed dark:text-neutral-300">{item.description}</p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<section id="works" class="mx-auto max-w-6xl px-4 py-20">
  <div class="mb-12 flex flex-col items-end justify-between md:flex-row">
    <div>
      <h2 class="mb-2 text-3xl font-bold tracking-tight text-neutral-900 md:text-4xl dark:text-white">
        {t('homeWorksTitle')}
      </h2>
      <p class="text-muted-light dark:text-muted-dark">{t('homeWorksSubtitle')}</p>
    </div>
    <a
      class="hover:text-muted-light dark:hover:text-muted-dark mt-4 hidden items-center gap-1 font-medium text-neutral-900 transition-colors md:mt-0 md:flex dark:text-white"
      href="https://github.com/visomi-dev"
      target="_blank"
    >
      <span>{t('homeWorksGithubLink')}</span>
      <span class="pi pi-arrow-up-right text-sm"></span>
    </a>
  </div>

  <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
    <div
      class="group border-border-light dark:border-border-dark relative overflow-hidden rounded-2xl border bg-white shadow-sm transition-colors duration-300 hover:border-neutral-400/40 hover:shadow-md dark:bg-neutral-900 dark:hover:border-neutral-600"
    >
      <div class="relative h-48 overflow-hidden bg-neutral-100 dark:bg-neutral-800">
        <div
          class="text-muted-light/10 dark:text-muted-dark/10 absolute inset-0 flex items-center justify-center text-6xl font-black select-none"
        >
          01
        </div>
        <div
          class="flex h-full w-full items-center justify-center bg-linear-to-br from-red-100 to-orange-100 transition-transform duration-500 group-hover:scale-105 dark:from-red-900/30 dark:to-orange-900/30"
        >
          <span class="pi pi-wallet text-5xl text-red-400/60 dark:text-red-400/40"></span>
        </div>
      </div>
      <div class="p-6">
        <div class="mb-4 flex items-start justify-between">
          <h3 class="text-xl font-semibold text-neutral-900 dark:text-white">{t('homeWorksProject1Title')}</h3>
          <span
            class="pi pi-external-link text-muted-light dark:text-muted-dark transition-colors group-hover:text-neutral-900 dark:group-hover:text-white"
          ></span>
        </div>
        <p class="text-muted-light dark:text-muted-dark mb-4 text-sm">{t('homeWorksProject1Desc')}</p>
        <div class="flex flex-wrap gap-2">
          <span
            class="border-border-light text-muted-light dark:border-border-dark dark:text-muted-dark rounded-md border bg-neutral-50 px-2 py-1 text-xs font-medium dark:bg-neutral-800"
            >{t('homeWorksProject1Tag1')}</span
          >
          <span
            class="border-border-light text-muted-light dark:border-border-dark dark:text-muted-dark rounded-md border bg-neutral-50 px-2 py-1 text-xs font-medium dark:bg-neutral-800"
            >{t('homeWorksProject1Tag2')}</span
          >
        </div>
      </div>
      <a href="https://nive.visomi.dev" target="_blank" class="absolute inset-0 z-10" aria-label="Visit Nive website"
      ></a>
    </div>

    <div
      class="group border-border-light dark:border-border-dark relative overflow-hidden rounded-2xl border bg-white shadow-sm transition-colors duration-300 hover:border-neutral-400/40 hover:shadow-md dark:bg-neutral-900 dark:hover:border-neutral-600"
    >
      <div class="relative h-48 overflow-hidden bg-neutral-100 dark:bg-neutral-800">
        <div
          class="text-muted-light/10 dark:text-muted-dark/10 absolute inset-0 flex items-center justify-center text-6xl font-black select-none"
        >
          02
        </div>
        <div
          class="flex h-full w-full items-center justify-center bg-linear-to-br from-blue-100 to-cyan-100 transition-transform duration-500 group-hover:scale-105 dark:from-blue-900/30 dark:to-cyan-900/30"
        >
          <span class="pi pi-desktop text-5xl text-blue-400/60 dark:text-blue-400/40"></span>
        </div>
      </div>
      <div class="p-6">
        <div class="mb-4 flex items-start justify-between">
          <h3 class="text-xl font-semibold text-neutral-900 dark:text-white">{t('homeWorksProject2Title')}</h3>
          <span
            class="pi pi-github text-muted-light dark:text-muted-dark transition-colors group-hover:text-neutral-900 dark:group-hover:text-white"
          ></span>
        </div>
        <p class="text-muted-light dark:text-muted-dark mb-4 text-sm">{t('homeWorksProject2Desc')}</p>
        <div class="flex flex-wrap gap-2">
          <span
            class="border-border-light text-muted-light dark:border-border-dark dark:text-muted-dark rounded-md border bg-neutral-50 px-2 py-1 text-xs font-medium dark:bg-neutral-800"
            >{t('homeWorksProject2Tag1')}</span
          >
          <span
            class="border-border-light text-muted-light dark:border-border-dark dark:text-muted-dark rounded-md border bg-neutral-50 px-2 py-1 text-xs font-medium dark:bg-neutral-800"
            >{t('homeWorksProject2Tag2')}</span
          >
        </div>
      </div>
      <a
        href="https://github.com/visomi-dev/visomi.dev"
        target="_blank"
        class="absolute inset-0 z-10"
        aria-label="View visomi.dev on GitHub"></a>
    </div>

    <div
      class="group border-border-light dark:border-border-dark relative overflow-hidden rounded-2xl border border-dashed bg-neutral-50/50 shadow-sm transition-colors duration-300 hover:border-neutral-400/40 dark:bg-neutral-900/50"
    >
      <div class="flex h-full flex-col items-center justify-center p-8 text-center">
        <div class="mb-4 rounded-full bg-neutral-100 p-4 dark:bg-neutral-800">
          <span class="pi pi-plus text-2xl text-neutral-400"></span>
        </div>
        <h3 class="mb-2 font-semibold text-neutral-900 dark:text-white">{t('homeWorksProject3Title')}</h3>
        <p class="text-muted-light dark:text-muted-dark text-sm">{t('homeWorksProject3Desc')}</p>
      </div>
    </div>
  </div>
</section>

<section class="px-4 py-20" id="features">
  <div class="mx-auto max-w-6xl">
    <div class="mb-16 text-center">
      <h2 class="mb-4 text-3xl font-bold tracking-tight text-neutral-900 md:text-4xl dark:text-white">
        {t('homeFeaturesTitle')}
      </h2>
      <p class="text-muted-light dark:text-muted-dark mx-auto max-w-2xl text-lg">{t('homeFeaturesSubtitle')}</p>
    </div>

    <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
      <div
        class="group border-border-light dark:border-border-dark rounded-2xl border bg-white p-8 shadow-sm transition-all duration-300 hover:border-neutral-400/40 hover:shadow-md dark:bg-neutral-900 dark:hover:border-neutral-600"
      >
        <div class="mb-6 flex items-start justify-between">
          <div>
            <h3 class="text-lg font-bold text-neutral-900 dark:text-white">{t('homeFeaturesCard1Title')}</h3>
            <p class="text-muted-light dark:text-muted-dark text-sm">{t('homeFeaturesCard1Subtitle')}</p>
          </div>
          <span
            class="rounded border border-emerald-100 bg-emerald-50 px-2 py-1 font-mono text-xs text-emerald-600 dark:border-emerald-800 dark:bg-emerald-900/30 dark:text-emerald-400"
            >{t('homeFeaturesCard1Badge')}</span
          >
        </div>
        <div
          class="border-border-light text-muted-light dark:border-border-dark dark:text-muted-dark rounded-lg border bg-neutral-50 p-4 font-mono text-[11px] dark:bg-neutral-800"
        >
          <p class="text-neutral-900 dark:text-white">$ npx nx graph</p>
          <p>Analyzing workspace dependencies... <span class="text-emerald-500">DONE</span></p>
          <p>Architecture: <span class="font-bold text-neutral-900 dark:text-white">Modular Monorepo</span></p>
          <p>
            Tech Stack: <span class="font-bold text-neutral-900 dark:text-white">Angular, React, Node.js, AWS</span>
          </p>
        </div>
      </div>

      <div
        class="group border-border-light dark:border-border-dark rounded-2xl border bg-white p-8 shadow-sm transition-all duration-300 hover:border-neutral-400/40 hover:shadow-md dark:bg-neutral-900 dark:hover:border-neutral-600"
      >
        <div class="mb-6 flex items-start justify-between">
          <div>
            <h3 class="text-lg font-bold text-neutral-900 dark:text-white">{t('homeFeaturesCard2Title')}</h3>
            <p class="text-muted-light dark:text-muted-dark text-sm">{t('homeFeaturesCard2Subtitle')}</p>
          </div>
          <span
            class="rounded border border-blue-100 bg-blue-50 px-2 py-1 font-mono text-xs text-blue-600 dark:border-blue-800 dark:bg-blue-900/30 dark:text-blue-400"
            >{t('homeFeaturesCard2Badge')}</span
          >
        </div>
        <div
          class="border-border-light text-muted-light dark:border-border-dark dark:text-muted-dark rounded-lg border bg-neutral-50 p-4 font-mono text-[11px] dark:bg-neutral-800"
        >
          <p><span class="text-purple-600 dark:text-purple-400">@theme</span> &#123;</p>
          <p class="pl-4">--color-primary: <span class="text-orange-600 dark:text-orange-400">#3B82F6</span>;</p>
          <p class="pl-4">--spacing-unit: <span class="text-orange-600 dark:text-orange-400">0.25rem</span>;</p>
          <p class="pl-4">--glass-effect: <span class="text-orange-600 dark:text-orange-400">blur(8px)</span>;</p>
          <p>&#125;</p>
        </div>
      </div>

      <div
        class="group border-border-light dark:border-border-dark rounded-2xl border bg-white p-8 shadow-sm transition-all duration-300 hover:border-neutral-400/40 hover:shadow-md dark:bg-neutral-900 dark:hover:border-neutral-600"
      >
        <div class="mb-6 flex items-start justify-between">
          <div>
            <h3 class="text-lg font-bold text-neutral-900 dark:text-white">{t('homeFeaturesCard3Title')}</h3>
            <p class="text-muted-light dark:text-muted-dark text-sm">{t('homeFeaturesCard3Subtitle')}</p>
          </div>
          <span
            class="border-border-light text-muted-light dark:border-border-dark dark:text-muted-dark rounded border bg-neutral-100 px-2 py-1 font-mono text-xs dark:bg-neutral-800"
            >Head of Tech</span
          >
        </div>
        <div
          class="border-border-light dark:border-border-dark flex items-center justify-center rounded-lg border bg-neutral-50 py-4 dark:bg-neutral-800"
        >
          <div class="flex items-center gap-3">
            <div
              class="border-muted-light dark:border-muted-dark flex h-10 w-10 items-center justify-center rounded border border-dashed text-[10px] tracking-tighter uppercase"
            >
              Vision
            </div>
            <span class="pi pi-arrow-right text-muted-light dark:text-muted-dark"></span>
            <div
              class="flex h-10 w-10 items-center justify-center rounded border border-neutral-900 bg-white text-[10px] tracking-tighter uppercase dark:border-white dark:bg-neutral-900"
            >
              Product
            </div>
            <span class="pi pi-arrow-right text-muted-light dark:text-muted-dark"></span>
            <div
              class="border-muted-light dark:border-muted-dark flex h-10 w-10 items-center justify-center rounded border border-dashed text-[10px] tracking-tighter uppercase"
            >
              Team
            </div>
          </div>
        </div>
      </div>

      <div
        class="group border-border-light dark:border-border-dark rounded-2xl border bg-white p-8 shadow-sm transition-all duration-300 hover:border-neutral-400/40 hover:shadow-md dark:bg-neutral-900 dark:hover:border-neutral-600"
      >
        <div class="mb-6 flex items-start justify-between">
          <div>
            <h3 class="text-lg font-bold text-neutral-900 dark:text-white">{t('homeFeaturesCard4Title')}</h3>
            <p class="text-muted-light dark:text-muted-dark text-sm">{t('homeFeaturesCard4Subtitle')}</p>
          </div>
          <div class="flex -space-x-1">
            <div class="h-5 w-5 rounded-full border-2 border-white bg-emerald-500 dark:border-neutral-900"></div>
            <div class="h-5 w-5 rounded-full border-2 border-white bg-emerald-500 dark:border-neutral-900"></div>
            <div class="h-5 w-5 rounded-full border-2 border-white bg-emerald-500 dark:border-neutral-900"></div>
          </div>
        </div>
        <div
          class="border-border-light text-muted-light dark:border-border-dark dark:text-muted-dark rounded-lg border bg-neutral-50 p-4 font-mono text-[11px] dark:bg-neutral-800"
        >
          <div class="mb-1 flex items-center justify-between">
            <span>{t('homeFeaturesA11yCheck1')}</span><span class="text-emerald-500">PASS</span>
          </div>
          <div class="mb-1 flex items-center justify-between">
            <span>{t('homeFeaturesA11yCheck2')}</span><span class="text-emerald-500">PASS</span>
          </div>
          <div class="flex items-center justify-between">
            <span>{t('homeFeaturesA11yCheck3')}</span><span class="text-emerald-500">PASS</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
