---
import { Image } from 'astro:assets';

import { getSiteContent } from '../content/site-content';
import type { Locale } from '../i18n/translations';

type Props = {
  locale: Locale;
};

const { locale } = Astro.props;
const { projects, projectsList } = getSiteContent(locale);
const sortedProjectsList = [...projectsList].sort((left, right) => Number(right.year) - Number(left.year));

const ui =
  locale === 'es'
    ? {
        caseStudiesLabel: 'Casos de estudio',
        screenNarrativeLabel: 'Narrativa visual',
        decisionsLabel: 'Decisiones del proyecto',
        technologiesLabel: 'Tecnologias',
        flowLabel: 'Parte del flujo',
        privateLabel: 'Vista privada',
        thumbnailLabel: 'Explorar pantallas',
        viewLabel: 'Vista',
      }
    : {
        caseStudiesLabel: 'Case studies',
        screenNarrativeLabel: 'Visual narrative',
        decisionsLabel: 'Project decisions',
        technologiesLabel: 'Technologies',
        flowLabel: 'Flow step',
        privateLabel: 'Private view',
        thumbnailLabel: 'Explore screens',
        viewLabel: 'View',
      };

const createScreenDetails = (project: (typeof projectsList)[number]) =>
  project.screenshots.map((screenshot, index) => {
    const highlight = project.highlights[index] ?? project.highlights[index - 1];
    const step = `${ui.flowLabel} ${String(index + 1).padStart(2, '0')}`;
    const description =
      index === 0
        ? project.summary
        : highlight
          ? `${highlight.label}: ${highlight.value}.`
          : locale === 'es'
            ? `Vista ${index + 1} del recorrido principal de ${project.title}.`
            : `View ${index + 1} of the main ${project.title} journey.`;

    return {
      step,
      title: screenshot.alt,
      description,
    };
  });
---

<main class="min-h-screen-nav mx-auto mt-20 max-w-[1680px] grow overflow-x-hidden px-6 pt-12 pb-12 2xl:px-10 2xl:pt-16 2xl:pb-16">
  <header class="mb-20">
    <div class="flex flex-col gap-6">
      <div class="text-muted-light dark:text-muted-dark flex items-center gap-3 font-mono text-xs tracking-wider">
        <span>{projects.pageLabel}</span>
      </div>
      <h1
        class="text-surface-dark dark:text-surface-light text-5xl leading-[1.1] font-semibold tracking-tight md:text-6xl"
      >
        <span>{projects.titleLine1}</span><br />
        <span class="text-muted-light dark:text-muted-dark">{projects.titleLine2}</span>
      </h1>
      <div class="mt-8 flex flex-col justify-between gap-12 md:flex-row md:items-end">
        <p class="text-muted-light dark:text-muted-dark max-w-2xl text-lg leading-relaxed font-light">
          {projects.description}
        </p>
        <div class="flex flex-wrap gap-2 font-mono text-xs" id="project-filters">
          {
            projects.filters.map((filter, index) => (
              <button
                data-filter={filter.value}
                class:list={[
                  'filter-btn rounded border px-4 py-2 transition-all',
                  index === 0
                    ? 'bg-primary-light dark:bg-primary-dark border-transparent text-white dark:text-black'
                    : 'border-border-light dark:border-border-dark text-muted-light dark:text-muted-dark hover:border-primary-light dark:hover:border-primary-dark bg-transparent',
                ]}
              >
                {filter.label}
              </button>
            ))
          }
        </div>
      </div>
    </div>
  </header>

  <section class="space-y-16 md:space-y-24" id="projects-grid">
    {
      sortedProjectsList.map((project) => {
        const featuredScreenshot = project.screenshots[0];
        const screenDetails = createScreenDetails(project);
        const activeScreen = screenDetails[0];
        const lightPreviewFrame = project.slug === 'circular-e' || project.slug === 'mesada';

        return (
          <article
            data-category={project.category}
            class="project-card border-border-light/70 dark:border-border-dark/70 relative border-t pt-16 first:pt-0"
          >
            <div class="grid gap-12 lg:grid-cols-[minmax(0,1fr)_minmax(0,1.18fr)] lg:gap-16 xl:gap-20 2xl:grid-cols-[minmax(0,1.05fr)_minmax(0,1.25fr)] 2xl:gap-24">
              <div class="space-y-8 lg:sticky lg:top-28 lg:self-start">
                <div class="space-y-6">
                  <div class="text-muted-light dark:text-muted-dark flex flex-wrap items-center gap-3 font-mono text-[10px] tracking-[0.28em] uppercase">
                    <span>{project.role}</span>
                    <span class="bg-border-light dark:bg-border-dark h-px w-6" />
                    <span>{project.year}</span>
                    <span class="bg-border-light dark:bg-border-dark h-px w-6" />
                    <span>{project.category}</span>
                  </div>

                  <div class="space-y-4">
                    <div class="flex items-center gap-4">
                      <div class="border-border-light dark:border-border-dark flex h-11 w-11 items-center justify-center rounded-2xl border bg-neutral-50 dark:bg-neutral-900/70">
                        <span class:list={['pi text-xl text-neutral-700 dark:text-neutral-300', project.icon]} />
                      </div>
                      <p class="text-muted-light dark:text-muted-dark font-mono text-[10px] tracking-[0.3em] uppercase">
                        {ui.caseStudiesLabel}
                      </p>
                    </div>

                    <h2 class="text-surface-dark dark:text-surface-light text-4xl leading-tight font-semibold tracking-tight md:text-5xl 2xl:text-6xl">
                      {project.title}
                    </h2>

                    <p class="text-muted-light dark:text-muted-dark max-w-xl text-base leading-8 font-light md:text-lg 2xl:max-w-2xl 2xl:text-xl 2xl:leading-9">
                      {project.summary}
                    </p>
                  </div>
                </div>

                {!project.privatePreview && activeScreen && (
                  <div class="border-border-light bg-surface-light/75 dark:border-border-dark dark:bg-surface-dark/60 rounded-3xl border p-6 backdrop-blur-sm">
                    <div class="mb-4 flex items-center gap-2">
                      <span class="h-2 w-2 rounded-full bg-blue-500" />
                      <p class="text-muted-light dark:text-muted-dark font-mono text-[10px] font-bold tracking-[0.24em] uppercase">
                        {ui.screenNarrativeLabel}
                      </p>
                    </div>

                    <p
                      class="text-muted-light dark:text-muted-dark mb-3 font-mono text-[10px] tracking-[0.24em] uppercase"
                      data-project-caption-step={project.slug}
                    >
                      {activeScreen.step}
                    </p>
                    <h3
                      class="text-surface-dark dark:text-surface-light text-xl font-semibold"
                      data-project-caption-title={project.slug}
                    >
                      {activeScreen.title}
                    </h3>
                    <p
                      class="text-muted-light dark:text-muted-dark mt-3 text-sm leading-7 2xl:text-base 2xl:leading-8"
                      data-project-caption-body={project.slug}
                    >
                      {activeScreen.description}
                    </p>
                  </div>
                )}

                <div class="space-y-4">
                  <div class="flex items-center gap-2">
                    <span class="h-2 w-2 rounded-full bg-emerald-500" />
                    <h3 class="text-muted-light dark:text-muted-dark font-mono text-[10px] font-bold tracking-[0.24em] uppercase">
                      {ui.decisionsLabel}
                    </h3>
                  </div>

                  <div class="grid gap-4 sm:grid-cols-2">
                    {project.highlights.map((highlight, index) => (
                      <div class="border-border-light bg-surface-light/70 dark:border-border-dark dark:bg-surface-dark/40 rounded-2xl border p-5">
                        <p class="text-muted-light dark:text-muted-dark mb-4 font-mono text-[10px] tracking-[0.24em] uppercase">
                          {String(index + 1).padStart(2, '0')}
                        </p>
                        <p class="text-surface-dark dark:text-surface-light text-lg leading-snug font-semibold">
                          {highlight.value}
                        </p>
                        <p class="text-muted-light dark:text-muted-dark mt-2 text-[11px] font-bold tracking-[0.22em] uppercase 2xl:text-xs">
                          {highlight.label}
                        </p>
                      </div>
                    ))}
                  </div>
                </div>

                <div class="space-y-4">
                  <h3 class="text-muted-light dark:text-muted-dark font-mono text-[10px] font-bold tracking-[0.24em] uppercase">
                    {ui.technologiesLabel}
                  </h3>
                  <div class="flex flex-wrap gap-2">
                    {project.technologies.map((technology) => (
                      <span class="border-border-light text-muted-light dark:border-border-dark dark:text-muted-dark rounded-full border bg-neutral-50/80 px-3 py-1.5 font-mono text-[10px] uppercase dark:bg-neutral-900/70">
                        {technology}
                      </span>
                    ))}
                  </div>
                </div>
              </div>

              <div class="space-y-5 lg:pt-4">
                <div class="relative overflow-x-clip">
                  <div class="border-border-light dark:border-border-dark absolute inset-0 translate-x-3 translate-y-3 rounded-[2rem] border bg-neutral-100/60 dark:bg-neutral-900/20" />
                  <div class="border-border-light dark:border-border-dark absolute inset-0 translate-x-6 translate-y-6 rounded-[2rem] border bg-neutral-100/35 dark:bg-neutral-900/10" />

                  <div class="border-border-light bg-surface-light dark:border-border-dark dark:bg-surface-dark relative overflow-hidden rounded-[2rem] border shadow-[0_24px_60px_-36px_rgba(15,23,42,0.45)]">
                    <div class="border-border-light dark:border-border-dark flex items-center justify-between border-b px-5 py-4">
                      <div class="flex items-center gap-2">
                        <span class="bg-border-light dark:bg-border-dark h-2.5 w-2.5 rounded-full" />
                        <span class="bg-border-light dark:bg-border-dark h-2.5 w-2.5 rounded-full" />
                        <span class="bg-border-light dark:bg-border-dark h-2.5 w-2.5 rounded-full" />
                      </div>
                      <div class="flex items-center gap-2">
                        <span class="text-muted-light dark:text-muted-dark rounded-full border border-current/15 px-3 py-1 font-mono text-[10px] tracking-[0.24em] uppercase">
                          {project.year}
                        </span>
                        <span class="text-muted-light dark:text-muted-dark rounded-full border border-current/15 px-3 py-1 font-mono text-[10px] tracking-[0.24em] uppercase">
                          {project.category}
                        </span>
                      </div>
                    </div>

                    {project.privatePreview ? (
                      <div class="flex aspect-[4/3] flex-col items-center justify-center gap-5 bg-linear-to-br from-neutral-100 to-neutral-200 p-10 text-center dark:from-neutral-950 dark:to-neutral-900">
                        <div class="border-border-light dark:border-border-dark flex h-16 w-16 items-center justify-center rounded-full border bg-white/70 dark:bg-neutral-900/80">
                          <span class="pi pi-lock text-2xl text-neutral-700 dark:text-neutral-300" />
                        </div>
                        <div class="space-y-3">
                          <p class="text-surface-dark dark:text-surface-light font-mono text-xs tracking-[0.25em] uppercase">
                            {projects.privatePreviewLabel}
                          </p>
                          <p class="text-muted-light dark:text-muted-dark mx-auto max-w-md text-sm leading-7">
                            {projects.privatePreviewDescription}
                          </p>
                        </div>
                      </div>
                    ) : featuredScreenshot ? (
                      <div
                        class:list={[
                          'p-5 dark:from-neutral-950 dark:via-neutral-950 dark:to-neutral-900',
                          lightPreviewFrame
                            ? 'bg-linear-to-br from-slate-100 via-neutral-100 to-slate-200'
                            : 'bg-linear-to-br from-white via-neutral-50 to-neutral-100',
                        ]}
                      >
                        <div
                          class:list={[
                            'relative aspect-[4/3] overflow-hidden rounded-[1.5rem] border shadow-[0_20px_45px_-30px_rgba(15,23,42,0.6)]',
                            lightPreviewFrame
                              ? 'border-black/8 bg-linear-to-br from-slate-50 via-white to-slate-100 ring-1 ring-black/6 dark:border-white/8 dark:bg-neutral-950 dark:ring-white/8'
                              : 'border-black/5 bg-white dark:border-white/5 dark:bg-black',
                          ]}
                        >
                          <Image
                            src={featuredScreenshot.src}
                            alt={featuredScreenshot.alt}
                            class:list={[
                              'project-preview h-full w-full object-top transition-all duration-300',
                              lightPreviewFrame ? 'object-contain p-4' : 'object-cover',
                            ]}
                            data-project-preview={project.slug}
                            widths={[640, 960, 1280]}
                            sizes="(min-width: 1024px) 52vw, 100vw"
                          />
                        </div>
                      </div>
                    ) : (
                      <div class="flex aspect-[4/3] items-center justify-center bg-linear-to-br from-neutral-100 to-neutral-200 dark:from-neutral-950 dark:to-neutral-900">
                        <span class="pi pi-image text-4xl text-neutral-400" />
                      </div>
                    )}
                  </div>
                </div>

                {project.screenshots.length > 1 && !project.privatePreview && (
                  <div class="space-y-3">
                    <div class="flex items-center gap-2">
                      <span class="h-2 w-2 rounded-full bg-violet-500" />
                      <h3 class="text-muted-light dark:text-muted-dark font-mono text-[10px] font-bold tracking-[0.24em] uppercase">
                        {ui.thumbnailLabel}
                      </h3>
                    </div>

                    <div class="grid gap-3 sm:grid-cols-2">
                      {project.screenshots.map((screenshot, index) => {
                        const detail = screenDetails[index];

                        return (
                          <button
                            type="button"
                            class:list={[
                              'project-thumb border-border-light bg-surface-light/70 dark:border-border-dark dark:bg-surface-dark/55 hover:border-primary-light dark:hover:border-primary-dark flex items-center gap-3 rounded-2xl border p-3 text-left transition-all',
                              index === 0 && 'ring-primary-light dark:ring-primary-dark ring-1',
                            ]}
                            data-project-thumb={project.slug}
                            data-image-src={screenshot.src.src}
                            data-image-alt={screenshot.alt}
                            data-caption-step={detail?.step}
                            data-caption-title={detail?.title}
                            data-caption-body={detail?.description}
                            aria-label={screenshot.alt}
                          >
                            <div class="overflow-hidden rounded-xl border border-black/5 dark:border-white/5">
                              <Image
                                src={screenshot.src}
                                alt={screenshot.alt}
                                class="h-20 w-20 object-cover object-top"
                                widths={[160, 320]}
                                sizes="160px"
                              />
                            </div>

                            <div class="min-w-0">
                              <p class="text-muted-light dark:text-muted-dark mb-1 font-mono text-[10px] tracking-[0.22em] uppercase 2xl:text-[11px]">
                                {detail?.step ?? `${ui.viewLabel} ${index + 1}`}
                              </p>
                              <p class="text-surface-dark dark:text-surface-light line-clamp-2 text-sm font-medium 2xl:text-base">
                                {detail?.title ?? screenshot.alt}
                              </p>
                            </div>
                          </button>
                        );
                      })}
                    </div>
                  </div>
                )}
              </div>
            </div>
          </article>
        );
      })
    }
  </section>
</main>

<script src="../scripts/projects.ts"></script>
