---
import { createTranslator, type Locale } from '../i18n/translations';

type Props = {
  locale: Locale;
  errors?: Partial<Record<'email' | 'message' | 'name' | 'type', string>>;
  formValues?: Partial<Record<'email' | 'message' | 'name' | 'type', string>>;
  status?: 'error' | 'sent' | null;
};

const { errors = {}, formValues = {}, locale, status = null } = Astro.props;
const t = createTranslator(locale);
const year = new Date().getFullYear();
const isSuccess = status === 'sent';
const isError = status === 'error';
---

<main class="min-h-screen-nav mx-auto mt-20 w-full max-w-[1800px] px-6 pt-10 pb-12 md:px-8 md:pt-14 2xl:px-12">
  <section class="grid gap-8 xl:grid-cols-[minmax(0,1.1fr)_minmax(24rem,40rem)] xl:items-center xl:gap-16 2xl:grid-cols-[minmax(0,1fr)_minmax(34rem,42rem)] 2xl:gap-24">
    <div class="min-w-0 space-y-8">
      <header class="flex max-w-3xl flex-col gap-5">
        <div class="text-muted-light dark:text-muted-dark flex items-center gap-3 font-mono text-xs tracking-wider">
          <span>{`// ${year} // ${t('contactPageLabel')}`}</span>
        </div>
        <h1
          class="text-surface-dark dark:text-surface-light max-w-[12ch] text-4xl leading-none font-semibold tracking-tight sm:text-5xl md:max-w-[11ch] md:text-6xl 2xl:text-7xl"
        >
          {t('contactPageTitle')}
        </h1>
        <p class="text-muted-light dark:text-muted-dark max-w-xl text-base leading-relaxed font-light sm:text-lg md:text-xl">
          {t('contactHeroDescription')}
        </p>
      </header>

      <div class="grid gap-6 md:max-w-xl md:grid-cols-[minmax(0,1fr)_auto] md:items-end xl:max-w-2xl">
        <div class="space-y-4">
      <div class="group flex cursor-pointer items-center gap-3">
        <span
          class="pi pi-envelope text-muted-light dark:text-muted-dark group-hover:text-surface-dark dark:group-hover:text-surface-light text-lg transition-colors"
        ></span>
        <a
          class="text-muted-light dark:text-muted-dark group-hover:text-surface-dark dark:group-hover:text-surface-light font-mono text-sm transition-colors"
          href="mailto:visomi.dev@gmail.com">visomi.dev@gmail.com</a
        >
      </div>
      <div class="group flex cursor-pointer items-center gap-3">
        <span
          class="pi pi-github text-muted-light dark:text-muted-dark group-hover:text-surface-dark dark:group-hover:text-surface-light text-lg transition-colors"
        ></span>
        <a
          class="text-muted-light dark:text-muted-dark group-hover:text-surface-dark dark:group-hover:text-surface-light font-mono text-sm transition-colors"
          href="https://github.com/visomi-dev"
          target="_blank">github.com/visomi-dev</a
        >
      </div>
        </div>

        <div class="border-border-light dark:border-border-dark rounded-2xl border border-dashed px-4 py-3 md:justify-self-start xl:justify-self-end">
          <div class="flex items-center gap-2">
            <span class="relative flex h-2 w-2">
              <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-emerald-400 opacity-75"></span>
              <span class="relative inline-flex h-2 w-2 rounded-full bg-emerald-500"></span>
            </span>
            <span class="text-muted-light dark:text-muted-dark font-mono text-[10px] font-bold tracking-widest uppercase"
              >{t('contactHeroStatus')}</span
            >
          </div>
        </div>
      </div>
    </div>

    <div class="xl:flex xl:justify-end">
    <div
      class="border-border-light dark:border-border-dark w-full rounded-2xl border bg-white p-6 shadow-sm transition-all duration-300 sm:p-8 md:p-10 xl:max-w-2xl dark:bg-neutral-900"
    >
      {(isSuccess || isError) && (
        <div
          class:list={[
            'mb-6 rounded-xl border px-4 py-3 text-sm leading-6',
            isSuccess
              ? 'border-emerald-200 bg-emerald-50 text-emerald-900 dark:border-emerald-900/60 dark:bg-emerald-950/40 dark:text-emerald-200'
              : 'border-red-200 bg-red-50 text-red-900 dark:border-red-900/60 dark:bg-red-950/40 dark:text-red-200',
          ]}
        >
          {isSuccess
            ? locale === 'es'
              ? 'Mensaje enviado. Te respondere pronto.'
              : 'Message sent. I will get back to you soon.'
            : locale === 'es'
              ? 'No se pudo enviar el mensaje. Intentalo de nuevo.'
              : 'The message could not be sent. Please try again.'}
        </div>
      )}

      <form method="POST" class="space-y-6">
        <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
          <div class="space-y-2">
            <label
              class="text-muted-light dark:text-muted-dark block font-mono text-[10px] font-bold tracking-widest uppercase"
              for="name">{t('contactFormLabelIdentity')}</label
            >
            <input
              type="text"
              id="name"
              name="name"
              class="border-border-light text-surface-dark focus:border-surface-dark dark:border-border-dark dark:text-surface-light dark:focus:border-surface-light w-full rounded border bg-white px-4 py-3 text-sm transition-all focus:ring-0 focus:outline-none dark:bg-neutral-950"
              placeholder={t('contactFormPlaceholderIdentity')}
              value={formValues.name}
              required
            />
            {errors.name && <p class="text-sm text-red-600 dark:text-red-300">{errors.name}</p>}
          </div>
          <div class="space-y-2">
            <label
              class="text-muted-light dark:text-muted-dark block font-mono text-[10px] font-bold tracking-widest uppercase"
              for="email">{t('contactFormLabelEmail')}</label
            >
            <input
              type="email"
              id="email"
              name="email"
              class="border-border-light text-surface-dark focus:border-surface-dark dark:border-border-dark dark:text-surface-light dark:focus:border-surface-light w-full rounded border bg-white px-4 py-3 text-sm transition-all focus:ring-0 focus:outline-none dark:bg-neutral-950"
              placeholder={t('contactFormPlaceholderEmail')}
              value={formValues.email}
              required
            />
            {errors.email && <p class="text-sm text-red-600 dark:text-red-300">{errors.email}</p>}
          </div>
        </div>

        <div class="space-y-2">
          <label
            class="text-muted-light dark:text-muted-dark block font-mono text-[10px] font-bold tracking-widest uppercase"
            for="type">{t('contactFormLabelProtocol')}</label
          >
          <div class="relative">
            <select
              class="border-border-light text-surface-dark focus:border-surface-dark dark:border-border-dark dark:text-surface-light dark:focus:border-surface-light w-full cursor-pointer appearance-none rounded border bg-white px-4 py-3 text-sm transition-all focus:ring-0 focus:outline-none dark:bg-neutral-950"
              id="type"
              name="type"
            >
              <option value="consulting" selected={formValues.type === 'consulting'}>{t('contactFormOptionConsulting')}</option>
              <option value="speaking" selected={formValues.type === 'speaking'}>{t('contactFormOptionSpeaking')}</option>
              <option value="fulltime" selected={formValues.type === 'fulltime'}>{t('contactFormOptionFulltime')}</option>
              <option value="other" selected={formValues.type === 'other'}>{t('contactFormOptionOther')}</option>
            </select>
            <div
              class="text-muted-light dark:text-muted-dark pointer-events-none absolute inset-y-0 right-0 flex items-center px-4"
            >
              <span class="pi pi-chevron-down text-sm"></span>
            </div>
          </div>
          {errors.type && <p class="text-sm text-red-600 dark:text-red-300">{errors.type}</p>}
        </div>

        <div class="space-y-2">
          <label
            class="text-muted-light dark:text-muted-dark block font-mono text-[10px] font-bold tracking-widest uppercase"
            for="message">{t('contactFormLabelPayload')}</label
          >
          <textarea
            class="border-border-light text-surface-dark focus:border-surface-dark dark:border-border-dark dark:text-surface-light dark:focus:border-surface-light w-full resize-none rounded border bg-white px-4 py-3 text-sm transition-all focus:ring-0 focus:outline-none dark:bg-neutral-950"
            id="message"
            name="message"
            placeholder={t('contactFormPlaceholderPayload')}
            rows="6"
            required>{formValues.message}</textarea>
          {errors.message && <p class="text-sm text-red-600 dark:text-red-300">{errors.message}</p>}
        </div>

        <div class="flex items-center justify-between pt-2">
          <button
            class="bg-surface-dark text-surface-light dark:bg-surface-light dark:text-surface-dark rounded border border-transparent px-6 py-3 font-mono text-[10px] font-bold tracking-widest uppercase transition-all hover:bg-neutral-800 active:scale-95 sm:px-8 dark:hover:bg-neutral-100"
            type="submit"
          >
            {t('contactFormButtonTransmit')}
          </button>
          <span class="text-muted-light/60 dark:text-muted-dark/40 hidden font-mono text-[10px] sm:inline-block"
            >{t('contactFormSecurityMsg')}</span
          >
        </div>
      </form>
    </div>
    </div>
  </section>

  <div class="border-border-light dark:border-border-dark col-span-12 mt-8 border-t pt-8 md:hidden">
    <div class="flex items-center gap-2">
      <span class="relative flex h-2 w-2">
        <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-emerald-400 opacity-75"></span>
        <span class="relative inline-flex h-2 w-2 rounded-full bg-emerald-500"></span>
      </span>
      <span class="text-muted-light dark:text-muted-dark font-mono text-xs font-bold tracking-widest uppercase"
        >{t('contactPageStatusMobile')}</span
      >
    </div>
  </div>
</main>
