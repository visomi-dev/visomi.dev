---
import '../styles/global.css';

import { getImage } from 'astro:assets';

import type { Locale, PageId } from '../i18n/translations';
import { getSeoImage } from '../content/seo-images';
import { getPagePath, locales } from '../i18n/translations';
import Background from '../components/background.astro';
import Footer from '../components/footer.astro';
import Navbar from '../components/navbar.astro';
import PageNavigationLoader from '../components/page-navigation-loader.astro';

type Props = {
  locale: Locale;
  page: PageId;
  title?: string;
  description: string;
};

const { locale, page, title, description } = Astro.props;
const siteTitle = 'VISOMI.DEV';
const documentTitle = title ? `${title} | ${siteTitle}` : siteTitle;
const baseUrl = Astro.site ?? Astro.url;
const canonicalUrl = new URL(getPagePath(locale, page), baseUrl).toString();
const defaultUrl = new URL(getPagePath('en', page), baseUrl).toString();
const seoImage = getSeoImage(page, locale);
const socialImage = await getImage({
  src: seoImage.image,
  width: 1200,
  height: 630,
  format: 'png',
});
const socialImageUrl = new URL(socialImage.src, baseUrl).toString();
---

<!doctype html>
<html lang={locale} class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <script is:inline>
      (() => {
        const html = document.documentElement;
        const isDark = (() => {
          try {
            const savedTheme = window.localStorage.getItem('theme');
            const systemDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
            return savedTheme === 'dark' || (!savedTheme && systemDark);
          } catch {
            return true;
          }
        })();

        html.classList.toggle('dark', isDark);
      })();
    </script>
    <title>{documentTitle}</title>
    <meta name="description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteTitle} />
    <meta property="og:locale" content={locale === 'es' ? 'es_ES' : 'en_US'} />
    <meta property="og:title" content={documentTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={socialImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={seoImage.alt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={documentTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImageUrl} />
    <meta name="twitter:image:alt" content={seoImage.alt} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="x-default" href={defaultUrl} />
    {
      locales.map((itemLocale) => (
        <link rel="alternate" hreflang={itemLocale} href={new URL(getPagePath(itemLocale, page), baseUrl).toString()} />
      ))
    }
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
  </head>
  <body class="min-h-full">
    <PageNavigationLoader />
    <Background />
    <Navbar locale={locale} currentPage={page} />

    <div class="relative z-10 min-h-screen">
      <slot />
    </div>

    <div class="relative z-10">
      <Footer locale={locale} />
    </div>
  </body>
</html>
