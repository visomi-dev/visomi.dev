---
import ProjectsPage from '../../../components/projects-page.astro';
import { createTranslator } from '../../../i18n/translations';
import BaseLayout from '../../../layouts/base-layout.astro';

const locale = 'es';
const t = createTranslator(locale);
const pageTitle = `${t('projectsTitle1')} ${t('projectsTitle2')}`;
---

<BaseLayout locale={locale} page="projects" title={pageTitle} description={t('projectsDescription')}>
  <ProjectsPage locale={locale} />
</BaseLayout>
