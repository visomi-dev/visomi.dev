---
import ProjectsPage from '../../components/projects-page.astro';
import { getSiteContent } from '../../content/site-content';
import BaseLayout from '../../layouts/base-layout.astro';

const locale = 'en';
const { projects } = getSiteContent(locale);
const pageTitle = `${projects.titleLine1} ${projects.titleLine2}`;
---

<BaseLayout locale={locale} page="projects" title={pageTitle} description={projects.description}>
  <ProjectsPage locale={locale} />
</BaseLayout>
