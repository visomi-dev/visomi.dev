---
import ResumePage from '../../components/resume-page.astro';
import { getSiteContent } from '../../content/site-content';
import BaseLayout from '../../layouts/base-layout.astro';

const locale = 'en';
const { resume } = getSiteContent(locale);
---

<BaseLayout locale={locale} page="resume" title={resume.pageLabel} description={resume.metaDescription}>
  <ResumePage locale={locale} />
</BaseLayout>
