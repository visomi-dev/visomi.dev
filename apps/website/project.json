{
  "name": "website",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/website/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/apps/website"],
      "options": {
        "command": "pnpm exec astro build --root apps/website --remote",
        "cwd": ".",
        "env": {
          "WEBSITE_OG_GENERATOR": "false"
        }
      }
    },
    "build-local": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/apps/website"],
      "options": {
        "command": "pnpm exec astro build --root apps/website --remote",
        "cwd": ".",
        "env": {
          "WEBSITE_OG_GENERATOR": "false"
        },
        "envFile": "./apps/website/.env"
      }
    },
    "build-static": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/apps/website"],
      "options": {
        "command": "pnpm exec astro build --root apps/website --remote",
        "cwd": ".",
        "env": {
          "WEBSITE_OUTPUT_MODE": "static"
        }
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "continuous": true,
      "options": {
        "command": "pnpm exec astro dev --root apps/website --host 0.0.0.0 --port 4200",
        "cwd": "."
      }
    },
    "preview": {
      "executor": "nx:run-commands",
      "continuous": true,
      "options": {
        "command": "pnpm exec astro build --root apps/website --remote && pnpm exec astro preview --root apps/website --host 0.0.0.0 --port 4300",
        "cwd": "."
      }
    },
    "preview-local": {
      "executor": "nx:run-commands",
      "continuous": true,
      "options": {
        "command": "pnpm exec astro build --root apps/website --remote && pnpm exec astro preview --root apps/website --host 0.0.0.0 --port 4300",
        "cwd": ".",
        "envFile": "./apps/website/.env"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm exec astro check --root apps/website",
        "cwd": "."
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/coverage/apps/website"],
      "options": {
        "command": "pnpm exec vitest run --config apps/website/vitest.config.ts --coverage",
        "cwd": "."
      }
    }
  }
}
