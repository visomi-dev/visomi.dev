{
  "name": "website",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/website",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "hugo -d ../../dist/apps/website --gc --minify",
        "cwd": "apps/website"
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "hugo server -D",
        "cwd": "apps/website",
        "port": 1313
      }
    },
    "preview": {
      "executor": "nx:run-commands",
      "options": {
        "command": "hugo -d ../../dist/apps/website-preview --gc --minify --baseURL /preview/",
        "cwd": "apps/website"
      }
    }
  }
}
