{
  "name": "website",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/website/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/apps/website"],
      "options": {
        "command": "pnpm exec astro build",
        "cwd": "apps/website"
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "continuous": true,
      "options": {
        "command": "pnpm exec astro dev --host 0.0.0.0 --port 4200",
        "cwd": "apps/website"
      }
    },
    "preview": {
      "executor": "nx:run-commands",
      "continuous": true,
      "options": {
        "command": "pnpm exec astro build && pnpm exec astro preview --host 0.0.0.0 --port 4300",
        "cwd": "apps/website"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm exec astro check",
        "cwd": "apps/website"
      }
    }
  }
}
